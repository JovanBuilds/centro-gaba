    <script>
      // Usamos el evento 'astro:page-load' para tener compatibilidad con el ViewTransitions / ClientRouter
      document.addEventListener("astro:page-load", () => {
        const themeToggle = document.getElementById("theme-toggle");
        const themeIcon = document.getElementById("theme-icon");

        const updateIcon = () => {
          const isDark =
            document.documentElement.classList.contains("dark") ||
            (!document.documentElement.classList.contains("light") &&
              window.matchMedia("(prefers-color-scheme: dark)").matches);

          const themeKnob = document.getElementById("theme-knob");
          const sunIcon = document.getElementById("sun-icon");
          const moonIcon = document.getElementById("moon-icon");

          if (themeKnob && sunIcon && moonIcon) {
            if (isDark) {
              themeKnob.style.transform = "translateX(28px)";
              moonIcon.style.filter = "grayscale(0)";
              moonIcon.style.opacity = "1";
              sunIcon.style.filter = "grayscale(100%)";
              sunIcon.style.opacity = "0.4";
            } else {
              themeKnob.style.transform = "translateX(0)";
              sunIcon.style.filter = "grayscale(0)";
              sunIcon.style.opacity = "1";
              moonIcon.style.filter = "grayscale(100%)";
              moonIcon.style.opacity = "0.4";
            }
          }
        };

        // Inicializar el ícono correcto al cargar
        updateIcon();

        // Detectar cambios en las preferencias del sistema en vivo para actualizar el ícono
        window
          .matchMedia("(prefers-color-scheme: dark)")
          .addEventListener("change", updateIcon);

        if (themeToggle) {
          themeToggle.addEventListener("click", () => {
            const isDark =
              document.documentElement.classList.contains("dark") ||
              (!document.documentElement.classList.contains("light") &&
                window.matchMedia("(prefers-color-scheme: dark)").matches);

            if (isDark) {
              // Cambiar a claro
              document.documentElement.classList.remove("dark");
              document.documentElement.classList.add("light");
              localStorage.setItem("theme", "light");
            } else {
              // Cambiar a oscuro
              document.documentElement.classList.add("dark");
              document.documentElement.classList.remove("light");
              localStorage.setItem("theme", "dark");
            }

            updateIcon();
          });
        }

        // Validacion fecha de nacimiento y Tutor Legal
        const inputNacimiento = document.getElementById(
          "fecha_nacimiento",
        ) as HTMLInputElement;
        const tutorDiv = document.getElementById("tutor_div");
        const inputTutor = document.getElementById("tutor") as HTMLInputElement;

        if (inputNacimiento && tutorDiv && inputTutor) {
          inputNacimiento.addEventListener("change", (e) => {
            const target = e.target as HTMLInputElement;
            if (!target.value) return;

            const birthDate = new Date(target.value);
            const today = new Date();
            let age = today.getFullYear() - birthDate.getFullYear();
            const m = today.getMonth() - birthDate.getMonth();
            if (m < 0 || (m === 0 && today.getDate() < birthDate.getDate())) {
              age--;
            }

            if (age < 18) {
              tutorDiv.classList.remove("hidden");
              inputTutor.setAttribute("required", "true");
            } else {
              tutorDiv.classList.add("hidden");
              inputTutor.removeAttribute("required");
              inputTutor.value = "";
            }
          });
        }
      });
    </script>
