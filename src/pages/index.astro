---
import Layout from "../layouts/Layout.astro";

// We'll use Astro's ViewTransitions for smooth page transitions between pages if any.
// Inside the single page we'll use Tailwind classes and CSS animations.
---

<Layout>
  <!-- Navbar Rediseñado (Dinámico Claro/Oscuro) -->
  <header
    class="relative md:fixed w-full z-50 bg-[var(--color-gaba-bg)]/90 backdrop-blur-md border-b border-[var(--color-gaba-border)] transition-all duration-300 shadow-sm"
  >
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 relative z-10">
      <div class="flex justify-between items-center h-20 gap-2">
        <!-- Logo y Título -->
        <div class="flex items-center gap-2 sm:gap-4 shrink-0">
          <div
            class="p-0.5 rounded-full bg-[var(--color-gaba-surface)] shadow-sm border border-[var(--color-gaba-border)] shrink-0"
          >
            <img
              src="/img/gaba_logo.jpg"
              alt="GABA Logo"
              class="h-11 w-11 rounded-full object-cover group-hover:scale-105 transition-transform"
            />
          </div>
          <span
            class="font-bold text-[0.85rem] sm:text-[1.05rem] leading-tight tracking-wide text-[var(--color-gaba-navy)] whitespace-nowrap"
          >
            <span class="hidden sm:inline">CENTRO PSICOLÓGICO<br /></span>
            <span class="sm:hidden text-[var(--color-gaba-blue)] text-[1.1rem]"
              >Centro GABA</span
            >
            <span
              class="hidden sm:inline text-[var(--color-gaba-blue)] text-[0.9rem]"
              >GABA</span
            >
          </span>
        </div>

        <!-- Enlaces Centrados -->
        <nav class="hidden md:flex justify-center items-center flex-1 gap-10">
          <a
            href="#inicio"
            class="relative group px-1 py-2 flex flex-col items-center justify-center"
          >
            <span
              class="text-[var(--color-gaba-navy)]/90 group-hover:text-[var(--color-gaba-navy)] font-medium text-[15px] tracking-wide transition-colors"
              >Inicio</span
            >
            <span
              class="absolute -bottom-1 w-0 h-[3px] bg-[var(--color-gaba-blue)] rounded-full transition-all duration-300 group-hover:w-full opacity-90"
            ></span>
          </a>

          <a
            href="#especialidades"
            class="relative group px-1 py-2 flex items-center justify-center gap-1"
          >
            <span
              class="text-[var(--color-gaba-navy)]/90 group-hover:text-[var(--color-gaba-navy)] font-medium text-[15px] tracking-wide transition-colors"
              >Especialidades</span
            >
            <svg
              class="w-0 opacity-0 group-hover:w-5 group-hover:opacity-100 text-[var(--color-gaba-blue)] transition-all duration-300 overflow-hidden"
              fill="none"
              viewBox="0 0 24 24"
              stroke="currentColor"
            >
              <path
                stroke-linecap="round"
                stroke-linejoin="round"
                stroke-width="1.5"
                d="M9.75 3.104v5.714a2.25 2.25 0 01-.659 1.591L5 14.5M9.75 3.104c-.251.023-.501.05-.75.082m.75-.082a24.301 24.301 0 014.5 0m0 0v5.714c0 .597.237 1.17.659 1.591L19.8 15.3M14.25 3.104c.251.023.501.05.75.082M19.8 15.3l-1.57.393A9.065 9.065 0 0112 15a9.065 9.065 0 00-6.23-.693L5 14.5m14.8.8l1.402 1.402c1.232 1.232.65 3.318-1.067 3.611A48.309 48.309 0 0112 21c-2.773 0-5.491-.235-8.135-.687-1.718-.293-2.3-2.379-1.067-3.61L5 14.5"
              ></path>
            </svg>
            <span
              class="absolute -bottom-1 left-1/2 -translate-x-1/2 w-0 h-[3px] bg-[var(--color-gaba-blue)] rounded-full transition-all duration-300 group-hover:w-full opacity-90"
            ></span>
          </a>

          <a
            href="#sedes"
            class="relative group px-1 py-2 flex flex-col items-center justify-center"
          >
            <span
              class="text-[var(--color-gaba-navy)]/90 group-hover:text-[var(--color-gaba-navy)] font-medium text-[15px] tracking-wide transition-colors"
              >Nuestras Sedes</span
            >
            <span
              class="absolute -bottom-1 w-0 h-[3px] bg-[var(--color-gaba-blue)] rounded-full transition-all duration-300 group-hover:w-full opacity-90"
            ></span>
          </a>
        </nav>

        <!-- Controles y CTA Derecha -->
        <div class="flex items-center justify-end gap-3 sm:gap-5 shrink-0">
          <!-- Selector de Tema Dinámico (Oculto en móvil) -->
          <button
            id="theme-toggle"
            aria-label="Cambiar tema"
            class="relative hidden md:flex items-center p-1 w-[64px] h-8 bg-[var(--color-gaba-surface-alt)] rounded-full shadow-inner border border-[var(--color-gaba-border)] outline-none focus:ring-1 focus:ring-[var(--color-gaba-blue)] transition-all overflow-hidden group"
          >
            <!-- Track Icons -->
            <div
              class="absolute inset-0 flex justify-between items-center px-1.5 pointer-events-none text-[13px] opacity-40"
            >
              <span>☀️</span>
              <span>🌙</span>
            </div>
            <!-- Knob -->
            <div
              id="theme-knob"
              class="absolute left-[3px] top-[3px] w-6 h-6 bg-[var(--color-gaba-surface)] rounded-full shadow-md border border-[var(--color-gaba-border)] transition-transform duration-400 ease-[cubic-bezier(0.68,-0.55,0.265,1.55)] flex items-center justify-center text-[12px] z-10"
            >
              <span id="knob-icon" class="transition-all duration-300">☀️</span>
            </div>
          </button>

          <!-- Botón CTA Premium -->
          <a
            href="#evaluacion"
            class="relative overflow-hidden inline-flex items-center justify-center px-4 sm:px-6 py-2 sm:py-2.5 rounded-full bg-[var(--color-gaba-green)] text-white font-bold text-[12px] sm:text-[14px] transition-all duration-300 shadow-md hover:shadow-xl hover:-translate-y-0.5 whitespace-nowrap group-hover:shadow-[0_0_15px_var(--color-gaba-green)] group"
          >
            <span
              class="absolute inset-0 w-[200%] h-full bg-gradient-to-r from-transparent via-white/30 to-transparent -translate-x-[150%] skew-x-[-25deg] group-hover:animate-[shine_1s_ease-out_forwards]"
            ></span>
            <span class="relative z-10 tracking-wide">Solicitar Evaluación</span
            >
          </a>

          <!-- Botón WhatsApp (Oculto en móvil) -->
          <a
            href="https://wa.me/526644801528"
            target="_blank"
            rel="noopener noreferrer"
            class="relative hidden md:inline-flex items-center justify-center p-2.5 rounded-full bg-[#25D366] text-white hover:bg-[#1ebd5b] transition-all duration-300 shadow-sm hover:shadow-md hover:-translate-y-0.5"
            aria-label="Consulta por WhatsApp"
            title="Envíanos un mensaje por WhatsApp"
          >
            <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 16 16">
              <path
                d="M13.601 2.326A7.85 7.85 0 0 0 7.994 0C3.627 0 .068 3.558.064 7.926c0 1.399.366 2.76 1.057 3.965L0 16l4.204-1.102a7.9 7.9 0 0 0 3.79.965h.004c4.368 0 7.926-3.558 7.93-7.93A7.9 7.9 0 0 0 13.6 2.326zM7.994 14.521a6.6 6.6 0 0 1-3.356-.92l-.24-.144-2.494.654.666-2.433-.156-.251a6.56 6.56 0 0 1-1.007-3.505c0-3.626 2.957-6.584 6.591-6.584a6.56 6.56 0 0 1 4.66 1.931 6.56 6.56 0 0 1 1.928 4.66c-.004 3.639-2.961 6.592-6.592 6.592m3.615-4.934c-.197-.099-1.17-.578-1.353-.646-.182-.065-.315-.099-.445.099-.133.197-.513.646-.627.775-.114.133-.232.148-.43.05-.197-.1-.836-.308-1.592-.985-.59-.525-.985-1.175-1.103-1.372-.114-.198-.011-.304.088-.403.087-.088.197-.232.296-.346.1-.114.133-.198.198-.33.065-.134.034-.248-.015-.347-.05-.099-.445-1.076-.612-1.47-.16-.389-.323-.335-.445-.34-.114-.007-.247-.007-.38-.007a.73.73 0 0 0-.529.247c-.182.198-.691.677-.691 1.654s.71 1.916.81 2.049c.098.133 1.394 2.132 3.383 2.992.47.205.84.326 1.129.418.475.152.904.129 1.246.08.38-.058 1.171-.48 1.338-.943.164-.464.164-.86.114-.943-.049-.084-.182-.133-.38-.232"
              ></path>
            </svg>
          </a>
        </div>
      </div>
    </div>
  </header>

  <!-- Hero Section -->
  <section
    id="inicio"
    class="relative pt-12 pb-20 md:pt-32 lg:pt-48 lg:pb-32 overflow-hidden"
  >
    <div
      class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 relative z-10 text-center"
    >
      <div
        class="inline-block mb-4 px-4 py-1.5 rounded-full bg-[var(--color-gaba-blue)]/10 border border-[var(--color-gaba-blue)]/20 text-[var(--color-gaba-blue)] font-medium text-sm animate-fade-in-up"
      >
        Especialistas en Salud Mental
      </div>
      <h1
        class="text-5xl md:text-6xl lg:text-7xl font-bold tracking-tight text-[var(--color-gaba-blue)] mb-6 animate-fade-in-up"
        style="animation-delay: 0.1s;"
      >
        Tu bienestar,<br class="hidden md:block" /> nuestra prioridad.
      </h1>
      <p
        class="mt-4 text-xl md:text-2xl text-[var(--color-gaba-navy)]/80 max-w-4xl mx-auto mb-10 animate-fade-in-up"
        style="animation-delay: 0.2s;"
      >
        Brindamos acompañamiento especializado a niños, adolescentes y jóvenes
        para potenciar sus habilidades, fortalecer su conducta y favorecer su
        aprendizaje.
      </p>
      <div
        class="flex justify-center animate-fade-in-up"
        style="animation-delay: 0.3s;"
      >
        <a
          href="#evaluacion"
          class="px-8 py-4 rounded-full bg-[var(--color-gaba-green)] text-white text-lg font-medium hover:bg-opacity-90 transition-all shadow-lg hover:shadow-xl transform hover:-translate-y-1"
        >
          Solicitar Evaluación Inicial
        </a>
      </div>
    </div>

    <!-- Decorative background elements -->
    <div
      class="absolute top-1/4 left-0 w-64 h-64 bg-[var(--color-gaba-blue)] rounded-full mix-blend-multiply filter blur-3xl opacity-10 animate-blob"
    >
    </div>
    <div
      class="absolute top-1/3 right-10 w-72 h-72 bg-[var(--color-gaba-green)] rounded-full mix-blend-multiply filter blur-3xl opacity-10 animate-blob animation-delay-2000"
    >
    </div>
  </section>

  <!-- Identidad Institucional Section -->
  <section
    id="identidad"
    class="py-24 bg-[var(--color-gaba-surface)] transition-colors duration-300 relative overflow-hidden"
  >
    <!-- Elementos decorativos minimalistas -->
    <div class="absolute -top-40 -left-40 w-96 h-96 bg-[var(--color-gaba-blue)]/5 rounded-full blur-3xl opacity-50 mix-blend-multiply pointer-events-none"></div>
    <div class="absolute -bottom-40 -right-40 w-96 h-96 bg-[var(--color-gaba-green)]/5 rounded-full blur-3xl opacity-50 mix-blend-multiply pointer-events-none"></div>

    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 relative z-10">
      
      <!-- Encabezado -->
      <div class="text-center mb-10 sm:mb-16 reveal-on-scroll opacity-0 translate-y-8 transition-all duration-1000 ease-out">
        <div class="inline-flex items-center gap-2 sm:gap-3 mb-3 sm:mb-4 justify-center">
          <svg class="w-5 h-5 sm:w-6 sm:h-6 text-[var(--color-gaba-green)]" fill="none" stroke="currentColor" viewBox="0 0 24 24">
             <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 6.253v13m0-13C10.832 5.477 9.246 5 7.5 5S4.168 5.477 3 6.253v13C4.168 18.477 5.754 18 7.5 18s3.332.477 4.5 1.253m0-13C13.168 5.477 14.754 5 16.5 5c1.747 0 3.332.477 4.5 1.253v13C19.832 18.477 18.247 18 16.5 18c-1.746 0-3.332.477-4.5 1.253"></path>
          </svg>
          <span class="text-[var(--color-gaba-green)] font-semibold tracking-wide uppercase text-xs sm:text-sm">Marco Institucional</span>
        </div>
        <h2 class="text-3xl sm:text-4xl font-bold text-[var(--color-gaba-blue)] mb-3 sm:mb-4">
          Nuestra Identidad
        </h2>
        <p class="text-sm sm:text-lg text-[var(--color-gaba-navy)]/70 max-w-2xl mx-auto px-2">
          El Centro Psicológico GABA es una red de colaboración ética y profesional dedicada al acompañamiento psicoeducativo y a la vinculación en salud mental.
        </p>
      </div>

      <!-- Bloque de Propósito (Misión y Visión) -->
      <div class="grid md:grid-cols-2 gap-4 sm:gap-6 md:gap-8 mb-20 sm:mb-24 reveal-on-scroll opacity-0 translate-y-8 transition-all duration-1000 delay-100 ease-out">
        <div class="flex flex-col items-center p-6 sm:p-10 rounded-2xl sm:rounded-3xl bg-[var(--color-gaba-surface-alt)] border border-[var(--color-gaba-border)]/60 shadow-sm hover:shadow-xl hover:border-[var(--color-gaba-blue)]/40 transition-all duration-300 transform hover:-translate-y-1 group relative overflow-hidden text-center">
          <div class="absolute -top-10 -right-10 w-24 h-24 sm:w-32 sm:h-32 bg-[var(--color-gaba-blue)]/5 rounded-full blur-2xl group-hover:bg-[var(--color-gaba-blue)]/10 transition-colors duration-500"></div>
          <div class="w-12 h-12 sm:w-16 sm:h-16 rounded-xl sm:rounded-2xl bg-[var(--color-gaba-surface)] shadow-sm flex items-center justify-center text-2xl sm:text-3xl mb-3 sm:mb-6 group-hover:scale-110 group-hover:rotate-3 transition-transform duration-300 border border-[var(--color-gaba-border)] z-10 shrink-0">
            🎯
          </div>
          <h3 class="text-[13px] sm:text-xl md:text-lg lg:text-xl font-bold text-[var(--color-gaba-navy)] mb-2 sm:mb-3 z-10 leading-tight">Misión</h3>
          <p class="text-[var(--color-gaba-navy)]/70 text-[11px] sm:text-sm leading-snug sm:leading-relaxed flex-grow z-10">
            Facilitar la conexión entre familias, pacientes y profesionales mediante intervenciones responsables y centradas en la persona, promoviendo el acceso a la salud mental con un trato ético y humano.
          </p>
        </div>

        <div class="flex flex-col items-center p-6 sm:p-10 rounded-2xl sm:rounded-3xl bg-[var(--color-gaba-surface-alt)] border border-[var(--color-gaba-border)]/60 shadow-sm hover:shadow-xl hover:border-[var(--color-gaba-green)]/40 transition-all duration-300 transform hover:-translate-y-1 group relative overflow-hidden text-center">
          <div class="absolute -top-10 -right-10 w-24 h-24 sm:w-32 sm:h-32 bg-[var(--color-gaba-green)]/5 rounded-full blur-2xl group-hover:bg-[var(--color-gaba-green)]/10 transition-colors duration-500"></div>
          <div class="w-12 h-12 sm:w-16 sm:h-16 rounded-xl sm:rounded-2xl bg-[var(--color-gaba-surface)] shadow-sm flex items-center justify-center text-2xl sm:text-3xl mb-3 sm:mb-6 group-hover:scale-110 group-hover:rotate-3 transition-transform duration-300 border border-[var(--color-gaba-border)] z-10 shrink-0">
            👁️
          </div>
          <h3 class="text-[13px] sm:text-xl md:text-lg lg:text-xl font-bold text-[var(--color-gaba-navy)] mb-2 sm:mb-3 z-10 leading-tight">Visión</h3>
          <p class="text-[var(--color-gaba-navy)]/70 text-[11px] sm:text-sm leading-snug sm:leading-relaxed flex-grow z-10">
            Consolidarse como un espacio confiable y sensible de colaboración en el ámbito de la salud mental, reconocido por su coherencia institucional y su claridad operativa frente a las necesidades individuales.
          </p>
        </div>
      </div>

      <!-- Archivos de Referencia Visual (Valores) -->
      <div class="mb-20 sm:mb-24 reveal-on-scroll opacity-0 translate-y-8 transition-all duration-1000 delay-200 ease-out">
        <div class="text-center mb-10 sm:mb-16">
          <h3 class="text-2xl sm:text-3xl font-bold text-[var(--color-gaba-blue)] mb-3">Valores Institucionales</h3>
        </div>
        <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-4 sm:gap-6 md:gap-8 text-center">
          <!-- Valor 1 -->
          <div class="group flex flex-col items-center p-6 sm:p-8 rounded-2xl sm:rounded-3xl bg-[var(--color-gaba-surface-alt)] border border-[var(--color-gaba-border)]/60 shadow-sm hover:shadow-xl hover:border-[var(--color-gaba-blue)]/40 transition-all duration-300 transform hover:-translate-y-1 relative overflow-hidden">
             <div class="absolute -top-10 -right-10 w-24 h-24 sm:w-32 sm:h-32 bg-[var(--color-gaba-blue)]/5 rounded-full blur-2xl group-hover:bg-[var(--color-gaba-blue)]/10 transition-colors duration-500"></div>
             <h4 class="text-[13px] sm:text-xl md:text-lg lg:text-xl font-bold text-[var(--color-gaba-navy)] mb-2 sm:mb-3 z-10 leading-tight">Ética</h4>
             <p class="text-[var(--color-gaba-navy)]/70 text-[11px] sm:text-sm leading-snug sm:leading-relaxed flex-grow z-10">
               Actuamos con estricto apego a los principios éticos, delimitando con claridad el alcance de nuestras funciones y responsabilidades.
             </p>
          </div>
          <!-- Valor 2 -->
          <div class="group flex flex-col items-center p-6 sm:p-8 rounded-2xl sm:rounded-3xl bg-[var(--color-gaba-surface-alt)] border border-[var(--color-gaba-border)]/60 shadow-sm hover:shadow-xl hover:border-[var(--color-gaba-blue)]/40 transition-all duration-300 transform hover:-translate-y-1 relative overflow-hidden">
             <div class="absolute -top-10 -right-10 w-24 h-24 sm:w-32 sm:h-32 bg-[var(--color-gaba-blue)]/5 rounded-full blur-2xl group-hover:bg-[var(--color-gaba-blue)]/10 transition-colors duration-500"></div>
             <h4 class="text-[13px] sm:text-xl md:text-lg lg:text-xl font-bold text-[var(--color-gaba-navy)] mb-2 sm:mb-3 z-10 leading-tight">Respeto</h4>
             <p class="text-[var(--color-gaba-navy)]/70 text-[11px] sm:text-sm leading-snug sm:leading-relaxed flex-grow z-10">
               Reconocemos la dignidad e historia de cada individuo. Evitamos prácticas estigmatizantes y promovemos un trato sensible y cuidadoso.
             </p>
          </div>
          <!-- Valor 3 -->
          <div class="group flex flex-col items-center p-6 sm:p-8 rounded-2xl sm:rounded-3xl bg-[var(--color-gaba-surface-alt)] border border-[var(--color-gaba-border)]/60 shadow-sm hover:shadow-xl hover:border-[var(--color-gaba-blue)]/40 transition-all duration-300 transform hover:-translate-y-1 relative overflow-hidden">
             <div class="absolute -top-10 -right-10 w-24 h-24 sm:w-32 sm:h-32 bg-[var(--color-gaba-blue)]/5 rounded-full blur-2xl group-hover:bg-[var(--color-gaba-blue)]/10 transition-colors duration-500"></div>
             <h4 class="text-[13px] sm:text-xl md:text-lg lg:text-xl font-bold text-[var(--color-gaba-navy)] mb-2 sm:mb-3 z-10 leading-tight">Autonomía</h4>
             <p class="text-[var(--color-gaba-navy)]/70 text-[11px] sm:text-sm leading-snug sm:leading-relaxed flex-grow z-10">
               Respetamos de manera firme la capacidad de decisión de las personas y procuramos un ejercicio ético respetando la clínica.
             </p>
          </div>
          <!-- Valor 4 -->
          <div class="group flex flex-col items-center p-6 sm:p-8 rounded-2xl sm:rounded-3xl bg-[var(--color-gaba-surface-alt)] border border-[var(--color-gaba-border)]/60 shadow-sm hover:shadow-xl hover:border-[var(--color-gaba-blue)]/40 transition-all duration-300 transform hover:-translate-y-1 relative overflow-hidden">
             <div class="absolute -top-10 -right-10 w-24 h-24 sm:w-32 sm:h-32 bg-[var(--color-gaba-blue)]/5 rounded-full blur-2xl group-hover:bg-[var(--color-gaba-blue)]/10 transition-colors duration-500"></div>
             <h4 class="text-[13px] sm:text-xl md:text-lg lg:text-xl font-bold text-[var(--color-gaba-navy)] mb-2 sm:mb-3 z-10 leading-tight">Colaboración</h4>
             <p class="text-[var(--color-gaba-navy)]/70 text-[11px] sm:text-sm leading-snug sm:leading-relaxed flex-grow z-10">
               Creemos plenamente en el trabajo en red como una forma eficaz de enriquecer la práctica profesional y fortalecer procesos.
             </p>
          </div>
          <!-- Valor 5 -->
          <div class="group flex flex-col items-center p-6 sm:p-8 rounded-2xl sm:rounded-3xl bg-[var(--color-gaba-surface-alt)] border border-[var(--color-gaba-border)]/60 shadow-sm hover:shadow-xl hover:border-[var(--color-gaba-blue)]/40 transition-all duration-300 transform hover:-translate-y-1 relative overflow-hidden">
             <div class="absolute -top-10 -right-10 w-24 h-24 sm:w-32 sm:h-32 bg-[var(--color-gaba-blue)]/5 rounded-full blur-2xl group-hover:bg-[var(--color-gaba-blue)]/10 transition-colors duration-500"></div>
             <h4 class="text-[13px] sm:text-xl md:text-lg lg:text-xl font-bold text-[var(--color-gaba-navy)] mb-2 sm:mb-3 z-10 leading-tight">Inclusión</h4>
             <p class="text-[var(--color-gaba-navy)]/70 text-[11px] sm:text-sm leading-snug sm:leading-relaxed flex-grow z-10">
               Promovemos entornos seguros, particularmente en el ámbito escolar, favoreciendo de manera activa su participación y adaptación.
             </p>
          </div>
          <!-- Valor 6 -->
          <div class="group flex flex-col items-center p-6 sm:p-8 rounded-2xl sm:rounded-3xl bg-[var(--color-gaba-surface-alt)] border border-[var(--color-gaba-border)]/60 shadow-sm hover:shadow-xl hover:border-[var(--color-gaba-blue)]/40 transition-all duration-300 transform hover:-translate-y-1 relative overflow-hidden">
             <div class="absolute -top-10 -right-10 w-24 h-24 sm:w-32 sm:h-32 bg-[var(--color-gaba-blue)]/5 rounded-full blur-2xl group-hover:bg-[var(--color-gaba-blue)]/10 transition-colors duration-500"></div>
             <h4 class="text-[13px] sm:text-xl md:text-lg lg:text-xl font-bold text-[var(--color-gaba-navy)] mb-2 sm:mb-3 z-10 leading-tight">Transparencia</h4>
             <p class="text-[var(--color-gaba-navy)]/70 text-[11px] sm:text-sm leading-snug sm:leading-relaxed flex-grow z-10">
               Comunicamos de manera honesta los alcances logrados, manteniendo siempre procesos ordenados y plenamente comprensibles.
             </p>
          </div>
        </div>
      </div>

      <!-- Referencia Operativa -->
      <div class="bg-[var(--color-gaba-surface-alt)] p-6 sm:p-12 border border-[var(--color-gaba-border)]/60 border-t-4 sm:border-t-0 sm:border-l-[3px] md:border-l-4 border-[var(--color-gaba-blue)] reveal-on-scroll opacity-0 translate-y-8 transition-all duration-1000 delay-300 ease-out shadow-sm rounded-2xl sm:rounded-3xl text-center md:text-left mx-auto max-w-5xl">
        <div class="flex flex-col md:flex-row md:items-center gap-6 sm:gap-8 justify-center">
