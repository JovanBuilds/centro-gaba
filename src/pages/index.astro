---
import Layout from "../layouts/Layout.astro";

// We'll use Astro's ViewTransitions for smooth page transitions between pages if any.
// Inside the single page we'll use Tailwind classes and CSS animations.
---

<Layout>
  <!-- Navbar Rediseñado (Dinámico Claro/Oscuro) -->
  <header
    class="fixed w-full z-50 bg-[var(--color-gaba-bg)]/90 backdrop-blur-md border-b border-[var(--color-gaba-border)] transition-all duration-300 shadow-sm"
  >
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 relative z-10">
      <div class="flex justify-between items-center h-20">
        <!-- Logo y Título -->
        <div class="flex items-center gap-4 w-1/4">
          <div
            class="p-0.5 rounded-full bg-[var(--color-gaba-surface)] shadow-sm border border-[var(--color-gaba-border)] shrink-0"
          >
            <img
              src="/img/gaba_logo.jpg"
              alt="GABA Logo"
              class="h-11 w-11 rounded-full object-cover group-hover:scale-105 transition-transform"
            />
          </div>
          <span
            class="font-bold text-[1.05rem] leading-tight tracking-wide text-[var(--color-gaba-navy)]"
          >
            CENTRO PSICOLÓGICO<br /><span
              class="text-[var(--color-gaba-blue)] text-[0.9rem]">GABA</span
            >
          </span>
        </div>

        <!-- Enlaces Centrados -->
        <nav class="hidden md:flex justify-center items-center flex-1 gap-10">
          <a
            href="#inicio"
            class="relative group px-1 py-2 flex flex-col items-center justify-center"
          >
            <span
              class="text-[var(--color-gaba-navy)]/90 group-hover:text-[var(--color-gaba-navy)] font-medium text-[15px] tracking-wide transition-colors"
              >Inicio</span
            >
            <span
              class="absolute -bottom-1 w-0 h-[3px] bg-[var(--color-gaba-blue)] rounded-full transition-all duration-300 group-hover:w-full opacity-90"
            ></span>
          </a>

          <a
            href="#especialidades"
            class="relative group px-1 py-2 flex items-center justify-center gap-1"
          >
            <span
              class="text-[var(--color-gaba-navy)]/90 group-hover:text-[var(--color-gaba-navy)] font-medium text-[15px] tracking-wide transition-colors"
              >Especialidades</span
            >
            <svg
              class="w-0 opacity-0 group-hover:w-5 group-hover:opacity-100 text-[var(--color-gaba-blue)] transition-all duration-300 overflow-hidden"
              fill="none"
              viewBox="0 0 24 24"
              stroke="currentColor"
            >
              <path
                stroke-linecap="round"
                stroke-linejoin="round"
                stroke-width="1.5"
                d="M9.75 3.104v5.714a2.25 2.25 0 01-.659 1.591L5 14.5M9.75 3.104c-.251.023-.501.05-.75.082m.75-.082a24.301 24.301 0 014.5 0m0 0v5.714c0 .597.237 1.17.659 1.591L19.8 15.3M14.25 3.104c.251.023.501.05.75.082M19.8 15.3l-1.57.393A9.065 9.065 0 0112 15a9.065 9.065 0 00-6.23-.693L5 14.5m14.8.8l1.402 1.402c1.232 1.232.65 3.318-1.067 3.611A48.309 48.309 0 0112 21c-2.773 0-5.491-.235-8.135-.687-1.718-.293-2.3-2.379-1.067-3.61L5 14.5"
              ></path>
            </svg>
            <span
              class="absolute -bottom-1 left-1/2 -translate-x-1/2 w-0 h-[3px] bg-[var(--color-gaba-blue)] rounded-full transition-all duration-300 group-hover:w-full opacity-90"
            ></span>
          </a>

          <a
            href="#sedes"
            class="relative group px-1 py-2 flex flex-col items-center justify-center"
          >
            <span
              class="text-[var(--color-gaba-navy)]/90 group-hover:text-[var(--color-gaba-navy)] font-medium text-[15px] tracking-wide transition-colors"
              >Nuestras Sedes</span
            >
            <span
              class="absolute -bottom-1 w-0 h-[3px] bg-[var(--color-gaba-blue)] rounded-full transition-all duration-300 group-hover:w-full opacity-90"
            ></span>
          </a>
        </nav>

        <!-- Controles y CTA Derecha -->
        <div class="flex items-center justify-end gap-5 w-1/4">
          <!-- Selector de Tema Dinámico -->
          <button
            id="theme-toggle"
            aria-label="Cambiar tema"
            class="relative flex items-center p-1 w-[64px] h-8 bg-[var(--color-gaba-surface-alt)] rounded-full shadow-inner border border-[var(--color-gaba-border)] outline-none focus:ring-1 focus:ring-[var(--color-gaba-blue)] transition-all overflow-hidden group"
          >
            <div
              id="theme-knob"
              class="absolute left-[3px] top-[3px] w-6 h-6 bg-[var(--color-gaba-surface)] rounded-full shadow-md border border-[var(--color-gaba-border)] transition-transform duration-400 ease-[cubic-bezier(0.68,-0.55,0.265,1.55)]"
            >
            </div>
            <div
              class="relative z-10 flex w-full justify-between px-1 text-[13px] pointer-events-none"
            >
              <span id="sun-icon" class="transition-all duration-300">☀️</span>
              <span
                id="moon-icon"
                class="transition-all duration-300 opacity-40 grayscale"
                >🌙</span
              >
            </div>
          </button>

          <!-- Botón CTA Premium -->
          <a
            href="#evaluacion"
            class="relative overflow-hidden inline-flex items-center justify-center px-6 py-2.5 rounded-full bg-[var(--color-gaba-green)] text-white font-bold text-[14px] transition-all duration-300 shadow-md hover:shadow-xl hover:-translate-y-0.5 whitespace-nowrap group-hover:shadow-[0_0_15px_var(--color-gaba-green)] group"
          >
            <span
              class="absolute inset-0 w-[200%] h-full bg-gradient-to-r from-transparent via-white/30 to-transparent -translate-x-[150%] skew-x-[-25deg] group-hover:animate-[shine_1s_ease-out_forwards]"
            ></span>
            <span class="relative z-10 tracking-wide">Solicitar Evaluación</span
            >
          </a>

          <!-- Botón WhatsApp -->
          <a
            href="https://wa.me/526646703603"
            target="_blank"
            rel="noopener noreferrer"
            class="relative inline-flex items-center justify-center p-2.5 rounded-full bg-[#25D366] text-white hover:bg-[#1ebd5b] transition-all duration-300 shadow-sm hover:shadow-md hover:-translate-y-0.5"
            aria-label="Consulta por WhatsApp"
            title="Envíanos un mensaje por WhatsApp"
          >
            <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 16 16">
              <path
                d="M13.601 2.326A7.85 7.85 0 0 0 7.994 0C3.627 0 .068 3.558.064 7.926c0 1.399.366 2.76 1.057 3.965L0 16l4.204-1.102a7.9 7.9 0 0 0 3.79.965h.004c4.368 0 7.926-3.558 7.93-7.93A7.9 7.9 0 0 0 13.6 2.326zM7.994 14.521a6.6 6.6 0 0 1-3.356-.92l-.24-.144-2.494.654.666-2.433-.156-.251a6.56 6.56 0 0 1-1.007-3.505c0-3.626 2.957-6.584 6.591-6.584a6.56 6.56 0 0 1 4.66 1.931 6.56 6.56 0 0 1 1.928 4.66c-.004 3.639-2.961 6.592-6.592 6.592m3.615-4.934c-.197-.099-1.17-.578-1.353-.646-.182-.065-.315-.099-.445.099-.133.197-.513.646-.627.775-.114.133-.232.148-.43.05-.197-.1-.836-.308-1.592-.985-.59-.525-.985-1.175-1.103-1.372-.114-.198-.011-.304.088-.403.087-.088.197-.232.296-.346.1-.114.133-.198.198-.33.065-.134.034-.248-.015-.347-.05-.099-.445-1.076-.612-1.47-.16-.389-.323-.335-.445-.34-.114-.007-.247-.007-.38-.007a.73.73 0 0 0-.529.247c-.182.198-.691.677-.691 1.654s.71 1.916.81 2.049c.098.133 1.394 2.132 3.383 2.992.47.205.84.326 1.129.418.475.152.904.129 1.246.08.38-.058 1.171-.48 1.338-.943.164-.464.164-.86.114-.943-.049-.084-.182-.133-.38-.232"
              ></path>
            </svg>
          </a>
        </div>
      </div>
    </div>
  </header>

  <!-- Hero Section -->
  <section
    id="inicio"
    class="relative pt-32 pb-20 lg:pt-48 lg:pb-32 overflow-hidden"
  >
    <div
      class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 relative z-10 text-center"
    >
      <div
        class="inline-block mb-4 px-4 py-1.5 rounded-full bg-[var(--color-gaba-blue)]/10 border border-[var(--color-gaba-blue)]/20 text-[var(--color-gaba-blue)] font-medium text-sm animate-fade-in-up"
      >
        Especialistas en Salud Mental
      </div>
      <h1
        class="text-5xl md:text-6xl lg:text-7xl font-bold tracking-tight text-[var(--color-gaba-blue)] mb-6 animate-fade-in-up"
        style="animation-delay: 0.1s;"
      >
        Tu bienestar,<br class="hidden md:block" /> nuestra prioridad.
      </h1>
      <p
        class="mt-4 text-xl md:text-2xl text-[var(--color-gaba-navy)]/80 max-w-4xl mx-auto mb-10 animate-fade-in-up"
        style="animation-delay: 0.2s;"
      >
        Brindamos acompañamiento especializado a niños, adolescentes y jóvenes
        para potenciar sus habilidades, fortalecer su conducta y favorecer su
        aprendizaje.
      </p>
      <div
        class="flex justify-center animate-fade-in-up"
        style="animation-delay: 0.3s;"
      >
        <a
          href="#evaluacion"
          class="px-8 py-4 rounded-full bg-[var(--color-gaba-green)] text-white text-lg font-medium hover:bg-opacity-90 transition-all shadow-lg hover:shadow-xl transform hover:-translate-y-1"
        >
          Solicitar Evaluación Inicial
        </a>
      </div>
    </div>

    <!-- Decorative background elements -->
    <div
      class="absolute top-1/4 left-0 w-64 h-64 bg-[var(--color-gaba-blue)] rounded-full mix-blend-multiply filter blur-3xl opacity-10 animate-blob"
    >
    </div>
    <div
      class="absolute top-1/3 right-10 w-72 h-72 bg-[var(--color-gaba-green)] rounded-full mix-blend-multiply filter blur-3xl opacity-10 animate-blob animation-delay-2000"
    >
    </div>
  </section>

  <!-- Especialidades / Servicios Section -->
  <section
    id="especialidades"
    class="py-20 bg-[var(--color-gaba-surface)] transition-colors duration-300 relative"
  >
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-16">
        <div class="inline-flex items-center gap-3 mb-4 justify-center">
          <svg
            class="w-6 h-6 text-[var(--color-gaba-green)]"
            fill="none"
            stroke="currentColor"
            viewBox="0 0 24 24"
            ><path
              stroke-linecap="round"
              stroke-linejoin="round"
              stroke-width="2"
              d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z"
            ></path></svg
          >
          <span
            class="text-[var(--color-gaba-green)] font-semibold tracking-wide uppercase text-sm"
            >Privacidad Garantizada</span
          >
        </div>
        <h2 class="text-4xl font-bold text-[var(--color-gaba-blue)] mb-4">
          Nuestros Servicios
        </h2>
        <p class="text-lg text-[var(--color-gaba-navy)]/70 max-w-2xl mx-auto">
          Ofrecemos intervenciones basadas en evidencia adaptadas a cada etapa
          del desarrollo, priorizando siempre el bienestar integral.
        </p>
      </div>

      <div
        class="flex flex-wrap justify-center items-stretch gap-6 md:gap-8 text-center"
      >
        <!-- Servicio 1 -->
        <article
          class="w-full sm:w-[calc(50%-0.75rem)] md:w-[calc(50%-1rem)] lg:w-[calc(33.333%-1.333rem)] flex flex-col items-center p-8 rounded-3xl bg-[var(--color-gaba-surface-alt)] border border-[var(--color-gaba-border)]/60 shadow-sm hover:shadow-xl hover:border-[var(--color-gaba-blue)]/40 transition-all duration-300 transform hover:-translate-y-1 group relative overflow-hidden"
        >
          <div
            class="absolute -top-10 -right-10 w-32 h-32 bg-[var(--color-gaba-blue)]/5 rounded-full blur-2xl group-hover:bg-[var(--color-gaba-blue)]/10 transition-colors duration-500"
          >
          </div>
          <div
            class="w-16 h-16 rounded-2xl bg-[var(--color-gaba-surface)] shadow-sm flex items-center justify-center text-3xl mb-6 group-hover:scale-110 group-hover:rotate-3 transition-transform duration-300 border border-[var(--color-gaba-border)] z-10 shrink-0"
          >
            🧸
          </div>
          <h3 class="text-xl font-bold text-[var(--color-gaba-navy)] mb-3 z-10">
            Psicoterapia Infantil
          </h3>
          <p
            class="text-[var(--color-gaba-navy)]/70 text-sm leading-relaxed flex-grow z-10"
          >
            Acompañamiento lúdico y empático para el desarrollo emocional pleno
            en la niñez.
          </p>
        </article>

        <!-- Servicio 2 -->
        <article
          class="w-full sm:w-[calc(50%-0.75rem)] md:w-[calc(50%-1rem)] lg:w-[calc(33.333%-1.333rem)] flex flex-col items-center p-8 rounded-3xl bg-[var(--color-gaba-surface-alt)] border border-[var(--color-gaba-border)]/60 shadow-sm hover:shadow-xl hover:border-[var(--color-gaba-blue)]/40 transition-all duration-300 transform hover:-translate-y-1 group relative overflow-hidden"
        >
          <div
            class="absolute -top-10 -right-10 w-32 h-32 bg-[var(--color-gaba-blue)]/5 rounded-full blur-2xl group-hover:bg-[var(--color-gaba-blue)]/10 transition-colors duration-500"
          >
          </div>
          <div
            class="w-16 h-16 rounded-2xl bg-[var(--color-gaba-surface)] shadow-sm flex items-center justify-center text-3xl mb-6 group-hover:scale-110 group-hover:rotate-3 transition-transform duration-300 border border-[var(--color-gaba-border)] z-10 shrink-0"
          >
            🛋️
          </div>
          <h3 class="text-xl font-bold text-[var(--color-gaba-navy)] mb-3 z-10">
            Terapia Cognitivo Conductual
          </h3>
          <p
            class="text-[var(--color-gaba-navy)]/70 text-sm leading-relaxed flex-grow z-10"
          >
            Atención estructurada para adultos, enfocada en resolver problemas
            actuales y modificar esquemas de pensamiento.
          </p>
        </article>

        <!-- Servicio 3 -->
        <article
          class="w-full sm:w-[calc(50%-0.75rem)] md:w-[calc(50%-1rem)] lg:w-[calc(33.333%-1.333rem)] flex flex-col items-center p-8 rounded-3xl bg-[var(--color-gaba-surface-alt)] border border-[var(--color-gaba-border)]/60 shadow-sm hover:shadow-xl hover:border-[var(--color-gaba-blue)]/40 transition-all duration-300 transform hover:-translate-y-1 group relative overflow-hidden"
        >
          <div
            class="absolute -top-10 -right-10 w-32 h-32 bg-[var(--color-gaba-green)]/5 rounded-full blur-2xl group-hover:bg-[var(--color-gaba-green)]/10 transition-colors duration-500"
          >
          </div>
          <div
            class="w-16 h-16 rounded-2xl bg-[var(--color-gaba-surface)] shadow-sm flex items-center justify-center text-3xl mb-6 group-hover:scale-110 group-hover:rotate-3 transition-transform duration-300 border border-[var(--color-gaba-border)] z-10 shrink-0"
          >
            📚
          </div>
          <h3 class="text-xl font-bold text-[var(--color-gaba-navy)] mb-3 z-10">
            Terapia de Aprendizaje
          </h3>
          <p
            class="text-[var(--color-gaba-navy)]/70 text-sm leading-relaxed flex-grow z-10"
          >
            Estrategias personalizadas para superar retos académicos y fomentar
            la asimilación efectiva de conocimientos.
          </p>
        </article>

        <!-- Servicio 4 -->
        <article
          class="w-full sm:w-[calc(50%-0.75rem)] md:w-[calc(50%-1rem)] lg:w-[calc(33.333%-1.333rem)] flex flex-col items-center p-8 rounded-3xl bg-[var(--color-gaba-surface-alt)] border border-[var(--color-gaba-border)]/60 shadow-sm hover:shadow-xl hover:border-[var(--color-gaba-blue)]/40 transition-all duration-300 transform hover:-translate-y-1 group relative overflow-hidden"
        >
          <div
            class="absolute -top-10 -right-10 w-32 h-32 bg-[var(--color-gaba-blue)]/5 rounded-full blur-2xl group-hover:bg-[var(--color-gaba-blue)]/10 transition-colors duration-500"
          >
          </div>
          <div
            class="w-16 h-16 rounded-2xl bg-[var(--color-gaba-surface)] shadow-sm flex items-center justify-center text-3xl mb-6 group-hover:scale-110 group-hover:rotate-3 transition-transform duration-300 border border-[var(--color-gaba-border)] z-10 shrink-0"
          >
            📋
          </div>
          <h3 class="text-xl font-bold text-[var(--color-gaba-navy)] mb-3 z-10">
            Evaluación en Neurodesarrollo
          </h3>
          <p
            class="text-[var(--color-gaba-navy)]/70 text-sm leading-relaxed flex-grow z-10"
          >
            Diagnóstico temprano e intervención oportuna para impulsar el
            potencial neurocognitivo.
          </p>
        </article>

        <!-- Servicio 5 -->
        <article
          class="w-full sm:w-[calc(50%-0.75rem)] md:w-[calc(50%-1rem)] lg:w-[calc(33.333%-1.333rem)] flex flex-col items-center p-8 rounded-3xl bg-[var(--color-gaba-surface-alt)] border border-[var(--color-gaba-border)]/60 shadow-sm hover:shadow-xl hover:border-[var(--color-gaba-blue)]/40 transition-all duration-300 transform hover:-translate-y-1 group relative overflow-hidden"
        >
          <div
            class="absolute -top-10 -right-10 w-32 h-32 bg-[var(--color-gaba-green)]/5 rounded-full blur-2xl group-hover:bg-[var(--color-gaba-green)]/10 transition-colors duration-500"
          >
          </div>
          <div
            class="w-16 h-16 rounded-2xl bg-[var(--color-gaba-surface)] shadow-sm flex items-center justify-center text-3xl mb-6 group-hover:scale-110 group-hover:rotate-3 transition-transform duration-300 border border-[var(--color-gaba-border)] z-10 shrink-0"
          >
            🔍
          </div>
          <h3 class="text-xl font-bold text-[var(--color-gaba-navy)] mb-3 z-10">
            Orientación Vocacional
          </h3>
          <p
            class="text-[var(--color-gaba-navy)]/70 text-sm leading-relaxed flex-grow z-10"
          >
            Acompañamiento enfocado en jóvenes para descubrir sus aptitudes e
            intereses, asegurando una trayectoria en armonía con sus objetivos
            vitales.
          </p>
        </article>
      </div>
    </div>
  </section>

  <!-- Sedes Section -->
  <section
    id="sedes"
    class="py-20 bg-[var(--color-gaba-surface)]/50 transition-colors duration-300 relative"
  >
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-16">
        <h2 class="text-4xl font-bold text-[var(--color-gaba-blue)] mb-4">
          🏫 Nuestras Sedes
        </h2>
        <p class="text-lg text-[var(--color-gaba-navy)]/70 max-w-2xl mx-auto">
          Pensando en tu comodidad, contamos con 5 centros de atención ubicados
          estratégicamente para estar siempre cerca de ti.
        </p>
      </div>

      <div
        class="flex flex-wrap justify-center items-stretch gap-6 md:gap-8 text-center"
      >
        <!-- Zona Río -->
        <article
          class="w-full sm:w-[calc(50%-0.75rem)] md:w-[calc(50%-1rem)] lg:w-[calc(33.333%-1.333rem)] flex flex-col items-center p-8 rounded-3xl bg-[var(--color-gaba-surface-alt)] border border-[var(--color-gaba-border)]/60 shadow-sm hover:shadow-xl hover:border-[var(--color-gaba-blue)]/40 transition-all duration-300 transform hover:-translate-y-1 group relative overflow-hidden"
        >
          <div
            class="absolute -top-10 -right-10 w-32 h-32 bg-[var(--color-gaba-blue)]/5 rounded-full blur-2xl group-hover:bg-[var(--color-gaba-blue)]/10 transition-colors duration-500"
          >
          </div>
          <div
            class="w-16 h-16 rounded-2xl bg-[var(--color-gaba-surface)] shadow-sm flex items-center justify-center text-3xl mb-6 group-hover:scale-110 group-hover:rotate-3 transition-transform duration-300 border border-[var(--color-gaba-border)] z-10 shrink-0"
          >
            🌟
          </div>
          <h3 class="text-xl font-bold text-[var(--color-gaba-navy)] mb-3 z-10">
            Zona Río
          </h3>
          <p
            class="text-[var(--color-gaba-navy)]/70 text-sm leading-relaxed flex-grow z-10"
          >
            Instalaciones de primera calidad y fácil acceso vehicular.
          </p>
        </article>

        <!-- Fundadores -->
        <article
          class="w-full sm:w-[calc(50%-0.75rem)] md:w-[calc(50%-1rem)] lg:w-[calc(33.333%-1.333rem)] flex flex-col items-center p-8 rounded-3xl bg-[var(--color-gaba-surface-alt)] border border-[var(--color-gaba-border)]/60 shadow-sm hover:shadow-xl hover:border-[var(--color-gaba-blue)]/40 transition-all duration-300 transform hover:-translate-y-1 group relative overflow-hidden"
        >
          <div
            class="absolute -top-10 -right-10 w-32 h-32 bg-[var(--color-gaba-blue)]/5 rounded-full blur-2xl group-hover:bg-[var(--color-gaba-blue)]/10 transition-colors duration-500"
          >
          </div>
          <div
            class="w-16 h-16 rounded-2xl bg-[var(--color-gaba-surface)] shadow-sm flex items-center justify-center text-3xl mb-6 group-hover:scale-110 group-hover:rotate-3 transition-transform duration-300 border border-[var(--color-gaba-border)] z-10 shrink-0"
          >
            🌟
          </div>
          <h3 class="text-xl font-bold text-[var(--color-gaba-navy)] mb-3 z-10">
            Fundadores
          </h3>
          <p
            class="text-[var(--color-gaba-navy)]/70 text-sm leading-relaxed flex-grow z-10"
          >
            Consultorios especializados para tu absoluta tranquilidad personal.
          </p>
        </article>

        <!-- La Cacho -->
        <article
          class="w-full sm:w-[calc(50%-0.75rem)] md:w-[calc(50%-1rem)] lg:w-[calc(33.333%-1.333rem)] flex flex-col items-center p-8 rounded-3xl bg-[var(--color-gaba-surface-alt)] border border-[var(--color-gaba-border)]/60 shadow-sm hover:shadow-xl hover:border-[var(--color-gaba-blue)]/40 transition-all duration-300 transform hover:-translate-y-1 group relative overflow-hidden"
        >
          <div
            class="absolute -top-10 -right-10 w-32 h-32 bg-[var(--color-gaba-blue)]/5 rounded-full blur-2xl group-hover:bg-[var(--color-gaba-blue)]/10 transition-colors duration-500"
          >
          </div>
          <div
            class="w-16 h-16 rounded-2xl bg-[var(--color-gaba-surface)] shadow-sm flex items-center justify-center text-3xl mb-6 group-hover:scale-110 group-hover:rotate-3 transition-transform duration-300 border border-[var(--color-gaba-border)] z-10 shrink-0"
          >
            🌟
